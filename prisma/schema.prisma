generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum ApplicationStatus {
  NEW
  IN_REVIEW
  APPROVED
  REJECTED
}

// ── Справочники (lookup tables) ────────────────────────────

model StaffType {
  id    Int     @id @default(autoincrement())
  name  String  @unique
  order Int     @default(0)
  staff Staff[]
}

model ProgramType {
  id      Int      @id @default(autoincrement())
  name    String   @unique
  order   Int      @default(0)
  courses Course[]
}

model LearningLevel {
  id      Int      @id @default(autoincrement())
  name    String   @unique
  order   Int      @default(0)
  courses Course[]
}

model LearningFormat {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  order     Int        @default(0)
  courses   Course[]
  practices Practice[]
}

model PracticeCategory {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  order     Int        @default(0)
  practices Practice[]
}

model ProjectCategory {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  order    Int       @default(0)
  projects Project[]
}

// ── Основные модели ────────────────────────────────────────

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Course {
  id            Int             @id @default(autoincrement())
  title         String
  slug          String          @unique
  description   String?
  image         String?
  published     Boolean         @default(false)
  modules       Json            @default("[]")
  lessons       Lesson[]
  applications  Application[]
  duration      String?
  price         String?
  startDate     DateTime?
  endDate       DateTime?
  programTypeId Int?
  programType   ProgramType?    @relation(fields: [programTypeId], references: [id])
  levelId       Int?
  level         LearningLevel?  @relation(fields: [levelId], references: [id])
  formatId      Int?
  format        LearningFormat? @relation(fields: [formatId], references: [id])
  teachers      Staff[]         @relation("CourseTeachers")
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model Lesson {
  id        Int      @id @default(autoincrement())
  courseId  Int
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title     String
  slug      String
  order     Int      @default(0)
  modules   Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([courseId, slug])
}

model Event {
  id           Int           @id @default(autoincrement())
  title        String
  slug         String        @unique
  date         DateTime
  location     String?
  description  String?
  image        String?
  published    Boolean       @default(false)
  modules      Json          @default("[]")
  applications Application[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Staff {
  id          Int        @id @default(autoincrement())
  name        String
  position    String
  department  String?
  bio         String?
  image       String?
  staffTypeId Int?
  staffType   StaffType? @relation(fields: [staffTypeId], references: [id])
  order       Int        @default(0)
  courses     Course[]   @relation("CourseTeachers")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Document {
  id        Int      @id @default(autoincrement())
  title     String
  category  String
  page      String?
  fileUrl   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Application {
  id        Int               @id @default(autoincrement())
  type      String
  status    ApplicationStatus @default(NEW)
  name      String
  email     String
  phone     String?
  message   String?
  workplace String?
  jobTitle  String?
  courseId  Int?
  course    Course?           @relation(fields: [courseId], references: [id], onDelete: SetNull)
  eventId   Int?
  event     Event?            @relation(fields: [eventId], references: [id], onDelete: SetNull)
  meta      Json              @default("{}")
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

model News {
  id        Int      @id @default(autoincrement())
  title     String
  slug      String   @unique
  summary   String?
  image     String?
  published Boolean  @default(false)
  modules   Json     @default("[]")
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Practice {
  id          Int               @id @default(autoincrement())
  title       String
  slug        String            @unique
  summary     String?
  image       String?
  published   Boolean           @default(false)
  modules     Json              @default("[]")
  categoryId  Int?
  category    PracticeCategory? @relation(fields: [categoryId], references: [id])
  company     String?
  formatId    Int?
  format      LearningFormat?   @relation(fields: [formatId], references: [id])
  deadline    DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model Project {
  id         Int              @id @default(autoincrement())
  title      String
  slug       String           @unique
  summary    String?
  image      String?
  published  Boolean          @default(false)
  modules    Json             @default("[]")
  categoryId Int?
  category   ProjectCategory? @relation(fields: [categoryId], references: [id])
  year       Int?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
}

model NewsletterSubscriber {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
}
